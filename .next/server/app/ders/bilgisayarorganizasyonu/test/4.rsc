4:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Hangisi Multibus II alt Sistemlerinden değildir?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Cevap\"}},{\"@type\":\"Question\",\"name\":\"Çok amaçlı kullanılabilen kapı aşağıdakilerden hangisidir?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Cevap\"}}]}"}}],["$","$Lf",null,{"courseId":"bilgisayarorganizasyonu","courseTitle":"Bilgisayar Organizasyonu ✅","testConfig":{"id":4,"title":"Deneme Sınavı 4","startIndex":60,"endIndex":62},"questions":[{"id":61,"questionText":"Hangisi Multibus II alt Sistemlerinden değildir?","imageUrl":null,"options":[{"letter":"A","text":"PCI-express baglantisi","isCorrect":false},{"letter":"B","text":"G/ç genişletmeleri için iSBX veri yolu","isCorrect":true},{"letter":"C","text":"Seri ve paralel sistem veri yollanı","isCorrect":false},{"letter":"D","text":"Bellek genişletme veri yolu","isCorrect":false},{"letter":"E","text":"CPU veri yolu","isCorrect":false}],"correctAnswer":"B","explanation":"**Doğru Cevap: G/ç genişletmeleri için iSBX veri yolu**\n\nBu problem, benzetim (simülasyon) teorisinde standart sistem yapıları veya ihtimal dağılımlarına dayanmaktadır. Simülasyon modeli kurgulanırken girdi verilerinin uygun bir istatistiksel dağılıma oturtulması veya kuyruk disiplini kurallarının doğru atanması gerekir. Çözüm, bu kurallara veya formüllere doğrudan karşılık gelmektedir."},{"id":62,"questionText":"Çok amaçlı kullanılabilen kapı aşağıdakilerden hangisidir?","imageUrl":null,"options":[{"letter":"A","text":"NAND","isCorrect":true},{"letter":"B","text":"XOR","isCorrect":false},{"letter":"C","text":"NOR","isCorrect":false},{"letter":"D","text":"NOT","isCorrect":false},{"letter":"E","text":"AND","isCorrect":false}],"correctAnswer":"A","explanation":"**Doğru Cevap: NAND**\n\nBu problem, benzetim (simülasyon) teorisinde standart sistem yapıları veya ihtimal dağılımlarına dayanmaktadır. Simülasyon modeli kurgulanırken girdi verilerinin uygun bir istatistiksel dağılıma oturtulması veya kuyruk disiplini kurallarının doğru atanması gerekir. Çözüm, bu kurallara veya formüllere doğrudan karşılık gelmektedir."}]}]]
