f:T11d1,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Yazılım projesi geliştirme aşamalarından biri olan ve öncelikle dikkat edilmesi gereken planlama aşaması ile ilgili aşağıdakilerden hangisi yanlıştır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"“Seçilen satıcı en düşük sahip olma maliyetini sağlayacak mı? Yoksa başka sebeplerden dolayı mı bu satıcı seçildi?” gibi soruların cevabını veren seçim kriteri hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi proje yönetimi planının güncellenebilecek öğelerinden birisi değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bilgi çağı yönetim akımı hangi tarihten sonra tam anlamıyla bir bilim şeklini almıştır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir yazılım projesinin iletişim yönetimi kısmında gerçekleşen ilerlemeyi, planlanan ilerleme ile karşılaştırmalı olarak değerlendirmeye olanak sağlayan tekniktir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi projede risk yönetiminin nasıl yaptırılacağını ve gerçekleşeceğinin açıklamak için izlenen yoldur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi risklerin tanımlanması kısmında kullanılan bir girdi değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir kaynak türü değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir yazılım projesinin iletişim yönetimi kısmında yargıya dayalı metotlar arasında yer almaz?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi çevik yöntemlerin ilkelerinden birisi değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi üst ve alt tanımlama sınırları, taraflar arasında yapılan sözleşmelere dayanan tekniktir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"“……….tarihsel bilgiler ile diğer değişkenler arasındaki istatistiksel ilişki kullanılarak maliyet, süre gibi aktivite parametreleri için tahmini değerler hesaplanır.” şeklinde verilen tanım aşağıdaki hangi tekniği açıklamaktadır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi risk yönetiminin olumlu sonuçlarından biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi fayda / maliyet analizinin avantajlarından birisi değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Kalite bir ürün veya hizmetin belirlenen veya olabilecek …………..karşılama kabiliyetine dayanan özelliklerin toplamıdır. şeklinde verilen tamamlamada boş bırakılan alana aşağıdakilerden hangisi getirilmelidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bir Üniversitenin gelirlerini artıracak yeni bir bölüm açmaya / yaratmaya yönelik projeye onay verilmesi aşağıdakilerden hangisi ile ifade edilir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Genellikle doğruluğu güvence altına almak için ürün kapsam tanımının çoğu zaman gözden geçirmeye imkan sağlayan girdi türü aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Projenin kullanıcı istek, teknik gereksinim ve standartlarını karşılayacak şekilde hatasız geliştirilmesi için gerekli kontrol testleri yapmaktan sorumlu olan kişi aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Projenin başlangıcından tamamlanmasına kadar, maliyet alternatiflerinin tanımlanmasını ve değerlendirmesini kapsayan sürece ne ad verilir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir projenin operasyon grubuna veya bir sonraki aşamaya aktarıldığını gösteren resmi dökümantasyondur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}}]}4:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$f"}}],"$L10"]
