f:T11c8,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"….., bir ihtiyacın mevcut insan ve mali vb. kaynaklarla yapılabilir olmasıdır. Yukarıdaki cümlede boş bırakılan yere aşağıdakilerden hangisi getirilmelidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi proje maliyetlerinin tahminine en çok etki eden faktörlerden birisi değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi proje tedarik yönetiminde çevresel işletme faktörlerinden biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Üst ve alt tanımlama sınırları ile taraflar arasında yapılan sözleşmelere dayanan teknik aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi projelerdeki entegrasyon planlarından biridir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi proje yönetim süreçlerinden biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bazı durumlarda proje yöneticisi bir işin süresini tahmin ederken eğer kendi deneyimlerine güvenmiyorsa veya süre tahminiyle ilgili fikir danışması gerektiğini düşünüyorsa farklı kişilerin görüşlerine de başvurur. Aşağıdakilerden hangisi yukarıda ifade edilen yöntemlerden biridir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi projelerde bütçenin belirlenmesi kısmında görüşü alınabilecek uzmanlardan biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Benzin sıkıntısına çözüm olarak yakıtı daha verimli kullanan otomobiller üretmek hangi sosyal ihtiyacın sonucu olarak oluşturulmuştur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Proje iletişim gereksinimlerinin belirlenmesinde aşağıda verilen bilgilerin hangisi kullanılamaz?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir yazılım projesindeki kapsam kavramının içerisinde yer almaz?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi proje zaman yönetiminde zaman çizelgesinin geliştirilmesi kısmında güncellenebilecek hususlardan biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Özellikle şirketlerin bir kazanç kapısı olarak geliştirdikleri yazılımlarla ilgilenen proje ekip üyesi aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Proje entegrasyon yönetiminde, projenin kapatılması aşamasından önce aşağıdaki aşamaların hangisi yer almaktadır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Yeni devreye alınacak örnek bir avans projedeki ilk sarmalda yapılacak işlemler düşünüldüğünde aşağıdakilerden hangisi doğru bir eşleşme olmaz?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Projede risk yönetiminin nasıl yapılandırılacağını ve gerçekleşeceğini açıklamak için izlenen yol aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir projede kalite planlanması kısmındaki girdilerden biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Proje türleri çeşitli olduğundan projeler için gerçekleştirilecek plan türleri de oldukça çeşitlidir. Bir projenin içerisinde de birçok farklı plan yapmak gerekebilir. şeklindeki bir ifade aşağıdakilerden hangisi için söylenebilir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"…… projenin başlatılması yönetilmesi yürütülmesi izlenmesi kontrolü ve kapatılmasını içermektedir. Yukarıdaki cümlede boş bırakılan yere aşağıdakilerden hangisi getirilmelidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bir yazılım projesinde herhangi bir kaynağın maliyet olarak kabul edilebilmesi için aşağıdakilerden hangisinin gerçekleşmesi gerekmektedir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}}]}4:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$f"}}],"$L10"]
