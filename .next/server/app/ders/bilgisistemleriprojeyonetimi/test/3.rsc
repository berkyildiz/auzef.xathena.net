f:Tfd3,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Belli bir anda bir yazılım projesinin ne kadarının tamamlandığı ne kadarının tamamlanmadığı net bir biçimde ölçülemez. Bunun sebebi yazılım projelerinin sahip olduğu özellik aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi proje yöneticilerinin sahip olması beklenen kişisel bir özellik değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir yazılımın kabul kriteri olabilir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Yazılım projelerinde maliyetler aşağıdakilerden hangisi ile ifade edilmez?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi projenin kapatılması kısmında kontrol edilmesi gereken hususlardan biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Risklerin projeyi etkileyebileceğini belirleme ve bunların özelliklerini belgeleme sürecine verilen ad aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Proje bütçesi ile ilgili gerçekleştirilen yedek maliyet analizi ile ilgili aşağıdakilerden hangisi yanlıştır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdaki kavram kısaltması ve eşleştirmelerden hangisi yanlıştır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bilimsel Yönetim akımı ile ilgili aşağıdaki hangi prensip tanımı doğru verilmiştir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi fayda-maliyet analizinde ele alınacak bir durumdur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Kritik yol metoduyla analiz edilmiş olan bir zaman çizelgesine uygulanan tekniğe verilen ad aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi gerçekleştirme aşamasının unsurlarından birisi değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi ürün kapsam tanımı hizmet tanımı sonuç tanımı kabul kriterleri hakkında önemli bilgiler içeren girdi olarak gösterilmektedir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi İnsan İlişkileri Okulu’ndaki temel prensiplerden biri değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdaki modellerin hangileri aynı kategori içerisinde yer alır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Kalite bir ürün veya hizmetin belirlenen veya olabilecek ….. karşılama kabiliyetine dayanan özelliklerin toplamıdır. Yukarıdaki cümlede boş bırakılan yere aşağıdakilerden hangisi getirilmelidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi bir paydaş sınıflandırma modeli değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bir cep telefonu firmasının büyük veri vb. gelişmelerin ardından daha hafif ve daha yüksek bellekli bir cep telefonu üretmek için yeni bir projeye onay vermesi aşağıdakilerden hangisi ile ifade edilebilir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Projelerdeki zaman ilişkileri belirlenirken en çok kullanılan öncel ilişkisi türü aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi proje maliyetine doğrudan etki eden bir faktör değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}}]}4:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$f"}}],"$L10"]
