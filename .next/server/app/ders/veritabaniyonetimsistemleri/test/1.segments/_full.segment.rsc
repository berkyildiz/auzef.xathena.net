f:T11f5,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"SELECT Adı, Ücret FROM PERSONEL WHERE Ücret > (SELECT AVG(Ücret) FROM PERSONEL); sorgusu aşağıdakilerden hangisini yapar?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"SELECT Görevi, SUM(Ücret) FROM PERSONEL WHERE Görevi <> ‘PAZARLAMACI’ GROUP BY Görevi HAVING SUM(Ücret)> 5000 ORDER BY SUM(Ücret); Yukarıdaki sorgu aşağıdakilerden hangisini yapar?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi veri tabanı tablolarını birleştirmek için kullanılan bir birleştirme türü değildir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"SQL’deki TO_CHAR ve TO_NUMBER fonksiyonlarının kullanımı ile ilgili aşağıdakilerden hangisi yanlıştır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"İsmi Tablo1, içerdiği alanlar Alan1, Alan2 ve Alan3 olan bir tablodaki bütün verilerin silinmesi için aşağıdaki komutlardan hangisi kullanılmalıdır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Alanları Adı, Soyadı ve İşeGirişTarihi şeklinde olan bir Personel tablosundaki personeller arasında o iş yerinde en az sürede çalışandan en çok sürede çalışana doğru bir sıralama işlemi gerçekleştiren SQL sorgusu aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bir veri tabanında depolanacak verileri kısıtlayan koşullar aşağıdakilerden hangisi ile ifade edilir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Bir veri tabanının temelini oluşturan ve bilgilerin tutulduğu nesne aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Veri tabanı tablolarında geçişli bağımlılıkların kaldırıldığı normalleşme formu aşağıdakilerden hangisidir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Tablo ve görünüm oluşturma yetkilerine sahip olan bir YÖNETİCİ rolü oluşturmak ve veri tabanı yönetim sistemindeki Ali ve Ayşe kullanıcılarına bu rol yetkisini vermek için aşağıdaki işlemlerden hangisi gerçekleştirilmez?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Veri tabanındaki bir tablonun bir kaydı ile diğer tablonun bir kaydı eşleştirilirse bu iki tablo arasındaki ilişki nasıl bir ilişki olur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi Ali isimli bir kullanıcının şifresini 1a2b3c4d5e6f olarak değiştirmek için kullanılan bir sorgudur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"SELECT Adı, Ücret FROM PERSONEL WHERE Ücret = (SELECT MIN (Ücret) FROM PERSONEL); sorgusunda hangi kısım alt sorgudur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"İlişkisel cebir işlemleri ile ilgili aşağıdakilerden hangisi doğrudur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdaki SQL sorgularından hangisi yanlış yazılmıştır?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdakilerden hangisi Select Adı & ‘Personeli’ & Ücret & ‘TL Ücret Alıyor…’ As Adı_Ücreti From Personel şeklinde verilen bir sorgunun sonucunda oluşan tabloda yer alan bir kayıt olabilir?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Aşağıdaki veri tabanı yönetim sistemlerinin hangisinde COMMIT ve ROLLBACK işlemlerine ihtiyaç duyulmaz?<","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Alanları PersonelNo, Adı, Görevi, Ücret, BölümNo olan bir PERSONEL tablosu ve alanları BölümNo, Bölüm Adı, Konum olan bir BÖLÜM tablosu arasındaki ilişki nasıl kurulur?","acceptedAnswer":{"@type":"Answer","text":"Cevap"}},{"@type":"Question","name":"Personel arasında görevi MEMUR olanlar